{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "build",
        "command": "dotnet",
        "type": "process",
        "args": ["build"],
        "problemMatcher": "$msCompile",
        "group": "build"
      },
      {
        "label": "run",
        "command": "dotnet",
        "type": "process",
        "args": ["run", "--project", "${workspaceFolder}"],
        "dependsOn": ["build"],
        "group": "none"
      }
    ]
  }
  