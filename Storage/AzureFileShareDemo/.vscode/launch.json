{
    "version": "0.2.0",
    "configurations": [
        
      {
        "name": "IIS Express",
        "type": "clr",
        "request": "launch",
        "preLaunchTask": "build",
        "program": "${workspaceFolder}/bin/Debug/net48/MyProject.dll",
        "cwd": "${workspaceFolder}",
        "stopAtEntry": false
      },
      {
        "name": ".NET Core Launch (web)",
        "type": "coreclr",
        "request": "launch",
        "preLaunchTask": "build",
        "program": "${workspaceFolder}/bin/Debug/net8.0/MyProject.dll",
        "cwd": "${workspaceFolder}",
        "stopAtEntry": false,
        "launchBrowser": {
          "enabled": true,
          "urls": "http://localhost:5000"
        }
      }
    ]
  }
  